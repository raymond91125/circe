@prefix cckg: <https://wormbase.org/resources/connectome/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cckg:Connectome a owl:Class ;
    rdfs:label "Connectome" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:connections ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:genes ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Connection ;
            owl:onProperty cckg:connections ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Gene ;
            owl:onProperty cckg:genes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:gene_expressions ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Cell ;
            owl:onProperty cckg:cells ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:cells ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:datasets ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:GeneExpression ;
            owl:onProperty cckg:gene_expressions ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Dataset ;
            owl:onProperty cckg:datasets ] ;
    skos:definition "Top-level container holding all cells, connections, and datasets of one build. Serves as the tree root for data files and validation." ;
    skos:inScheme cckg:schema .

cckg:schema.owl.ttl a owl:Ontology ;
    rdfs:label "celegans-connectome" ;
    dcterms:license "MIT" ;
    dcterms:title "C. elegans Connectome Knowledge Graph Schema" ;
    skos:definition "LinkML schema (single source of truth) for the C. elegans connectome knowledge graph. Models cells (neurons/muscles grounded in WBBT anatomy), reified n-ary connections (chemical synapse, gap junction, functional), the datasets that observe them, and a first-class, additive provenance layer. RDF/OWL, JSON-Schema, and Python dataclasses are generated from this file." .

cckg:Connection a owl:Class ;
    rdfs:label "Connection" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:weight ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:weight ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty cckg:weight ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Evidence ;
            owl:onProperty cckg:evidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Cell ;
            owl:onProperty cckg:post ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:ConnectionType ;
            owl:onProperty cckg:connection_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:post ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Dataset ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Cell ;
            owl:onProperty cckg:pre ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:post ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:connection_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:pre ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:connection_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:pre ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:id ] ;
    skos:definition "A reified, n-ary connection between two cells observed in one dataset. Reified (not a plain triple) because it carries type, weight, dataset, and evidence." ;
    skos:inScheme cckg:schema .

cckg:GeneExpression a owl:Class ;
    rdfs:label "GeneExpression" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:isoform ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:evidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:ExpressionConfidence ;
            owl:onProperty cckg:confidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:isoform ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:confidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:isoform ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Evidence ;
            owl:onProperty cckg:evidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:confidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Cell ;
            owl:onProperty cckg:cell ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Dataset ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Gene ;
            owl:onProperty cckg:gene ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:cell ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:gene ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:cell ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:gene ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:id ] ;
    skos:definition "A reified assertion that a cell expresses a gene, compiled in one dataset. Reified (not a plain triple) because it carries the source dataset, evidence, an optional transcript-isoform qualifier (when the source resolves expression to an isoform), and a confidence mark." ;
    skos:inScheme cckg:schema .

<https://wormbase.org/resources/connectome/CellType#muscle> a owl:Class ;
    rdfs:label "muscle" ;
    rdfs:subClassOf cckg:CellType ;
    skos:definition "A muscle cell." .

<https://wormbase.org/resources/connectome/CellType#neuron> a owl:Class ;
    rdfs:label "neuron" ;
    rdfs:subClassOf cckg:CellType ;
    skos:definition "A neuron." .

<https://wormbase.org/resources/connectome/CellType#other> a owl:Class ;
    rdfs:label "other" ;
    rdfs:subClassOf cckg:CellType ;
    skos:definition "Another non-neuronal cell carried by neuron-graph." .

<https://wormbase.org/resources/connectome/ConnectionType#chemical> a owl:Class ;
    rdfs:label "chemical" ;
    rdfs:subClassOf cckg:ConnectionType ;
    skos:definition "Chemical synapse (EM)." .

<https://wormbase.org/resources/connectome/ConnectionType#functional> a owl:Class ;
    rdfs:label "functional" ;
    rdfs:subClassOf cckg:ConnectionType ;
    skos:definition "Functional connectivity (FunCoNN)." .

<https://wormbase.org/resources/connectome/ConnectionType#gap_junction> a owl:Class ;
    rdfs:label "gap_junction" ;
    rdfs:subClassOf cckg:ConnectionType ;
    skos:definition "Electrical / gap-junction connection (EM)." .

<https://wormbase.org/resources/connectome/EvidenceType#aggregated_weight> a owl:Class ;
    rdfs:label "aggregated_weight" ;
    rdfs:subClassOf cckg:EvidenceType ;
    skos:definition "An aggregated connection weight observed in a dataset (v1)." .

<https://wormbase.org/resources/connectome/EvidenceType#synaptic_contact> a owl:Class ;
    rdfs:label "synaptic_contact" ;
    rdfs:subClassOf cckg:EvidenceType ;
    skos:definition "An individual synaptic contact (reserved for a later release)." .

<https://wormbase.org/resources/connectome/ExpressionConfidence#putative> a owl:Class ;
    rdfs:label "putative" ;
    rdfs:subClassOf cckg:ExpressionConfidence ;
    skos:definition "Weaker / putative expression (SI6 lowercase \"x\"); semantics unstated in source." .

<https://wormbase.org/resources/connectome/ExpressionConfidence#reported> a owl:Class ;
    rdfs:label "reported" ;
    rdfs:subClassOf cckg:ExpressionConfidence ;
    skos:definition "Expression reported (SI6 uppercase \"X\")." .

<https://wormbase.org/resources/connectome/GeneCategory#innexin> a owl:Class ;
    rdfs:label "innexin" ;
    rdfs:subClassOf cckg:GeneCategory ;
    skos:definition "Innexin / gap-junction channel gene." .

<https://wormbase.org/resources/connectome/GeneCategory#ionotropic_receptor> a owl:Class ;
    rdfs:label "ionotropic_receptor" ;
    rdfs:subClassOf cckg:GeneCategory ;
    skos:definition "Ionotropic (ligand-gated ion channel) neurotransmitter receptor." .

<https://wormbase.org/resources/connectome/GeneCategory#metabotropic_receptor> a owl:Class ;
    rdfs:label "metabotropic_receptor" ;
    rdfs:subClassOf cckg:GeneCategory ;
    skos:definition "Metabotropic (G-protein-coupled) neurotransmitter receptor." .

<https://wormbase.org/resources/connectome/GeneCategory#neuropeptide> a owl:Class ;
    rdfs:label "neuropeptide" ;
    rdfs:subClassOf cckg:GeneCategory ;
    skos:definition "Neuropeptide-encoding gene." .

<https://wormbase.org/resources/connectome/Sex#hermaphrodite> a owl:Class ;
    rdfs:label "hermaphrodite" ;
    rdfs:subClassOf cckg:Sex ;
    skos:definition "XX self-fertilizing hermaphrodite." .

<https://wormbase.org/resources/connectome/Sex#male> a owl:Class ;
    rdfs:label "male" ;
    rdfs:subClassOf cckg:Sex ;
    skos:definition "XO male." .

cckg:cells a owl:ObjectProperty ;
    rdfs:label "cells" ;
    skos:inScheme cckg:schema .

cckg:connections a owl:ObjectProperty ;
    rdfs:label "connections" ;
    skos:inScheme cckg:schema .

cckg:datasets a owl:ObjectProperty ;
    rdfs:label "datasets" ;
    skos:inScheme cckg:schema .

cckg:gene_expressions a owl:ObjectProperty ;
    rdfs:label "gene_expressions" ;
    skos:inScheme cckg:schema .

cckg:genes a owl:ObjectProperty ;
    rdfs:label "genes" ;
    skos:inScheme cckg:schema .

cckg:sexes a owl:ObjectProperty ;
    rdfs:label "sexes" ;
    rdfs:range cckg:Sex ;
    skos:definition "The sex(es) in which this cell is present, derived from the datasets that observe it. A shared cell has both; sex-specific cells have one — e.g. HSN/VC (hermaphrodite), the male ray neurons R1-R9, CEM, HOA/HOB, SPC, PCA/PCB/PCC, PDC (male). Class-level placeholder cells (``unspecified`` = true) carry no sexes: they stand in for unresolved individual cells, so asserting a sex-presence from dataset membership would be spurious (e.g. \"VAn\" appears only in a hermaphrodite dataset, but VA-class neurons are not hermaphrodite-specific)." ;
    skos:inScheme cckg:schema .

cckg:Evidence a owl:Class ;
    rdfs:label "Evidence" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:source ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Dataset ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:evidence_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:source ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:dataset ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:evidence_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty cckg:source ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:EvidenceType ;
            owl:onProperty cckg:evidence_type ] ;
    skos:definition "Provenance for a connection. Designed to be additive: v1 records an aggregated weight observed in a dataset; later releases can add individual synaptic-contact detail (section, volume, image) by adding optional slots, without schema churn." ;
    skos:inScheme cckg:schema .

cckg:Gene a owl:Class ;
    rdfs:label "Gene" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:systematic_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:category ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:systematic_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:systematic_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:category ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:GeneCategory ;
            owl:onProperty cckg:category ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:symbol ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:symbol ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:symbol ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:id ] ;
    skos:definition "A C. elegans gene, keyed by its persistent WormBase gene id (WB:WBGene…) as resolved via the Alliance of Genome Resources. Carries the gene symbol, WormBase systematic name, and a functional category. Genes are shared across gene-expression datasets." ;
    skos:inScheme cckg:schema .

cckg:anatomy a owl:DatatypeProperty ;
    rdfs:label "anatomy" ;
    rdfs:range xsd:anyURI ;
    skos:definition "The WBBT anatomy term this cell is grounded in." ;
    skos:inScheme cckg:schema .

cckg:category a owl:ObjectProperty ;
    rdfs:label "category" ;
    rdfs:range cckg:GeneCategory ;
    skos:definition "The functional category of the gene, as grouped by the source dataset." ;
    skos:inScheme cckg:schema .

cckg:cell a owl:ObjectProperty ;
    rdfs:label "cell" ;
    rdfs:range cckg:Cell ;
    skos:definition "The cell in which the gene is expressed." ;
    skos:inScheme cckg:schema .

cckg:cell_class a owl:DatatypeProperty ;
    rdfs:label "cell_class" ;
    skos:definition "The neuron-graph cell class (e.g. \"ADA\" for ADAL/ADAR)." ;
    skos:inScheme cckg:schema .

cckg:cell_type a owl:ObjectProperty ;
    rdfs:label "cell_type" ;
    rdfs:range cckg:CellType ;
    skos:definition "The broad kind of cell." ;
    skos:inScheme cckg:schema .

cckg:confidence a owl:ObjectProperty ;
    rdfs:label "confidence" ;
    rdfs:range cckg:ExpressionConfidence ;
    skos:definition "The source's expression mark for this assertion." ;
    skos:inScheme cckg:schema .

cckg:connection_type a owl:ObjectProperty ;
    rdfs:label "connection_type" ;
    rdfs:range cckg:ConnectionType ;
    skos:definition "The kind of connection." ;
    skos:inScheme cckg:schema .

cckg:description a owl:DatatypeProperty ;
    rdfs:label "description" ;
    skos:definition "Free-text description." ;
    skos:inScheme cckg:schema .

cckg:embryonic a owl:DatatypeProperty ;
    rdfs:label "embryonic" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the cell is born embryonically." ;
    skos:inScheme cckg:schema .

cckg:evidence_type a owl:ObjectProperty ;
    rdfs:label "evidence_type" ;
    rdfs:range cckg:EvidenceType ;
    skos:definition "What kind of evidence this record represents." ;
    skos:inScheme cckg:schema .

cckg:gene a owl:ObjectProperty ;
    rdfs:label "gene" ;
    rdfs:range cckg:Gene ;
    skos:definition "The expressed gene." ;
    skos:inScheme cckg:schema .

cckg:in_head a owl:DatatypeProperty ;
    rdfs:label "in_head" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the cell is in the head." ;
    skos:inScheme cckg:schema .

cckg:in_tail a owl:DatatypeProperty ;
    rdfs:label "in_tail" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the cell is in the tail." ;
    skos:inScheme cckg:schema .

cckg:isoform a owl:DatatypeProperty ;
    rdfs:label "isoform" ;
    skos:definition "Transcript-isoform qualifier from the source (e.g. \"a\", \"b\") when it distinguishes isoforms; expression stays keyed to the persistent gene. Absent when the source is gene-level." ;
    skos:inScheme cckg:schema .

cckg:nemanode_type a owl:DatatypeProperty ;
    rdfs:label "nemanode_type" ;
    skos:definition "Raw NemaNode cell-type code (e.g. \"i\", \"s\", \"sm\", \"b\"). Retained verbatim for the lossless viz projection; the curated CellType is in `cell_type`." ;
    skos:inScheme cckg:schema .

cckg:neurotransmitter a owl:DatatypeProperty ;
    rdfs:label "neurotransmitter" ;
    skos:definition "neuron-graph neurotransmitter code (e.g. \"l\", \"a\", \"g\", \"n\")." ;
    skos:inScheme cckg:schema .

cckg:post a owl:ObjectProperty ;
    rdfs:label "post" ;
    rdfs:range cckg:Cell ;
    skos:definition "The postsynaptic / target cell." ;
    skos:inScheme cckg:schema .

cckg:pre a owl:ObjectProperty ;
    rdfs:label "pre" ;
    rdfs:range cckg:Cell ;
    skos:definition "The presynaptic / source cell." ;
    skos:inScheme cckg:schema .

cckg:sex a owl:ObjectProperty ;
    rdfs:label "sex" ;
    rdfs:range cckg:Sex ;
    skos:definition "The biological sex of the specimen(s) the dataset observed." ;
    skos:inScheme cckg:schema .

cckg:source a owl:DatatypeProperty ;
    rdfs:label "source" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Pointer to the source data (file, URL, or upstream identifier)." ;
    skos:inScheme cckg:schema .

cckg:strain a owl:DatatypeProperty ;
    rdfs:label "strain" ;
    skos:definition "The C. elegans strain/genotype of the specimen, if known." ;
    skos:inScheme cckg:schema .

cckg:symbol a owl:DatatypeProperty ;
    rdfs:label "symbol" ;
    skos:definition "The gene's WormBase symbol (e.g. \"gar-1\")." ;
    skos:inScheme cckg:schema .

cckg:systematic_name a owl:DatatypeProperty ;
    rdfs:label "systematic_name" ;
    skos:definition "The WormBase systematic / sequence name (e.g. \"C15B12.5\")." ;
    skos:inScheme cckg:schema .

cckg:unspecified a owl:DatatypeProperty ;
    rdfs:label "unspecified" ;
    rdfs:range xsd:boolean ;
    skos:definition "True when this cell is a class- or group-level placeholder minted for a connection endpoint that the source did not resolve to a specific individual cell — e.g. \"VAn\" (an unspecified VA-class motor neuron) or a pharyngeal muscle class such as \"pm3\". Such nodes are not individual cells and carry no sex-presence (empty ``sexes``), so per-cell analyses (sex-specificity, cell counts) can exclude them." ;
    skos:inScheme cckg:schema .

cckg:value a owl:DatatypeProperty ;
    rdfs:label "value" ;
    skos:definition "The evidence payload as text (e.g. the aggregated weight value)." ;
    skos:inScheme cckg:schema .

cckg:weight a owl:DatatypeProperty ;
    rdfs:label "weight" ;
    rdfs:range xsd:float ;
    skos:definition "Aggregated connection weight as reported by the observing dataset." ;
    skos:inScheme cckg:schema .

cckg:EvidenceType a owl:Class ;
    rdfs:label "EvidenceType" ;
    owl:unionOf ( <https://wormbase.org/resources/connectome/EvidenceType#aggregated_weight> <https://wormbase.org/resources/connectome/EvidenceType#synaptic_contact> ) ;
    skos:inScheme cckg:schema ;
    linkml:permissible_values <https://wormbase.org/resources/connectome/EvidenceType#aggregated_weight>,
        <https://wormbase.org/resources/connectome/EvidenceType#synaptic_contact> .

cckg:ExpressionConfidence a owl:Class ;
    rdfs:label "ExpressionConfidence" ;
    owl:unionOf ( <https://wormbase.org/resources/connectome/ExpressionConfidence#reported> <https://wormbase.org/resources/connectome/ExpressionConfidence#putative> ) ;
    skos:definition "The source's expression mark. Cook 2020 SI6 uses uppercase \"X\" and lowercase \"x\"; the distinction is not defined in the source, so lowercase is taken as lower-confidence." ;
    skos:inScheme cckg:schema ;
    linkml:permissible_values <https://wormbase.org/resources/connectome/ExpressionConfidence#putative>,
        <https://wormbase.org/resources/connectome/ExpressionConfidence#reported> .

cckg:evidence a owl:ObjectProperty ;
    rdfs:label "evidence" ;
    rdfs:range cckg:Evidence ;
    skos:definition "Provenance records supporting this connection (open-world, additive)." ;
    skos:inScheme cckg:schema .

cckg:CellType a owl:Class ;
    rdfs:label "CellType" ;
    owl:unionOf ( <https://wormbase.org/resources/connectome/CellType#neuron> <https://wormbase.org/resources/connectome/CellType#muscle> <https://wormbase.org/resources/connectome/CellType#other> ) ;
    skos:inScheme cckg:schema ;
    linkml:permissible_values <https://wormbase.org/resources/connectome/CellType#muscle>,
        <https://wormbase.org/resources/connectome/CellType#neuron>,
        <https://wormbase.org/resources/connectome/CellType#other> .

cckg:ConnectionType a owl:Class ;
    rdfs:label "ConnectionType" ;
    owl:unionOf ( <https://wormbase.org/resources/connectome/ConnectionType#chemical> <https://wormbase.org/resources/connectome/ConnectionType#gap_junction> <https://wormbase.org/resources/connectome/ConnectionType#functional> ) ;
    skos:inScheme cckg:schema ;
    linkml:permissible_values <https://wormbase.org/resources/connectome/ConnectionType#chemical>,
        <https://wormbase.org/resources/connectome/ConnectionType#functional>,
        <https://wormbase.org/resources/connectome/ConnectionType#gap_junction> .

cckg:Dataset a owl:Class ;
    rdfs:label "Dataset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:sex ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:strain ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:sex ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:strain ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Sex ;
            owl:onProperty cckg:sex ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:strain ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:id ] ;
    skos:definition "A specimen/dataset that observes connections (an EM reconstruction or functional-imaging dataset), from neuron-graph (White 1986, Witvliet 2020, Randi funconn) or Cook et al. 2019." ;
    skos:inScheme cckg:schema .

cckg:GeneCategory a owl:Class ;
    rdfs:label "GeneCategory" ;
    owl:unionOf ( <https://wormbase.org/resources/connectome/GeneCategory#metabotropic_receptor> <https://wormbase.org/resources/connectome/GeneCategory#ionotropic_receptor> <https://wormbase.org/resources/connectome/GeneCategory#innexin> <https://wormbase.org/resources/connectome/GeneCategory#neuropeptide> ) ;
    skos:definition "Functional category a gene is grouped under in an expression dataset." ;
    skos:inScheme cckg:schema ;
    linkml:permissible_values <https://wormbase.org/resources/connectome/GeneCategory#innexin>,
        <https://wormbase.org/resources/connectome/GeneCategory#ionotropic_receptor>,
        <https://wormbase.org/resources/connectome/GeneCategory#metabotropic_receptor>,
        <https://wormbase.org/resources/connectome/GeneCategory#neuropeptide> .

cckg:Sex a owl:Class ;
    rdfs:label "Sex" ;
    owl:unionOf ( <https://wormbase.org/resources/connectome/Sex#hermaphrodite> <https://wormbase.org/resources/connectome/Sex#male> ) ;
    skos:definition "The biological sex of a C. elegans specimen." ;
    skos:inScheme cckg:schema ;
    linkml:permissible_values <https://wormbase.org/resources/connectome/Sex#hermaphrodite>,
        <https://wormbase.org/resources/connectome/Sex#male> .

cckg:name a owl:DatatypeProperty ;
    rdfs:label "name" ;
    skos:definition "Human-readable label." ;
    skos:inScheme cckg:schema .

cckg:Cell a owl:Class ;
    rdfs:label "Cell" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:unspecified ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:cell_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:neurotransmitter ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:unspecified ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:embryonic ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:cell_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty cckg:unspecified ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:neurotransmitter ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:neurotransmitter ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:anatomy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:cell_class ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:embryonic ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:sexes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:nemanode_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty cckg:embryonic ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:CellType ;
            owl:onProperty cckg:cell_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:cell_class ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:anatomy ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:cell_class ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:nemanode_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:in_tail ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:nemanode_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty cckg:anatomy ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty cckg:in_head ],
        [ a owl:Restriction ;
            owl:allValuesFrom cckg:Sex ;
            owl:onProperty cckg:sexes ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:in_tail ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:in_head ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty cckg:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty cckg:in_tail ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty cckg:in_head ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty cckg:id ] ;
    skos:definition "A C. elegans cell (neuron or muscle, or other non-neuronal cell carried by neuron-graph), keyed by its neuron-graph name and grounded in a WBBT anatomy term. Carries the neuron-graph-native attributes so the viz JSON projection is lossless." ;
    skos:inScheme cckg:schema .

cckg:dataset a owl:ObjectProperty ;
    rdfs:label "dataset" ;
    rdfs:range cckg:Dataset ;
    skos:definition "The dataset in which this was observed." ;
    skos:inScheme cckg:schema .

cckg:id a owl:DatatypeProperty ;
    rdfs:label "id" ;
    skos:definition "Stable identifier for the record." ;
    skos:inScheme cckg:schema .


# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Build artifacts
/dist/
/build/

# Generated outputs (regenerated by the pipeline)
/outputs/*
!/outputs/.gitkeep

# Generated schema-doc Markdown (regenerated by scripts/gen-schema-docs.sh + CI);
# the OWL (.ttl) and JSON Schema (.json) exports under docs/schema/ ARE committed.
/docs/schema/*.md

# OS
.DS_Store

# LibreOffice lock files
.~lock.*#

# MkDocs build output (schema docs site; deployed to Pages by CI)
/site/

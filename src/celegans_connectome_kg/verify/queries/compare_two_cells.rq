# Compare the connectivity of two cells side by side, broken out by dataset. For each
# partner, connection type, and dataset, sums the connection weight to each of the two
# cells — so left/right (or class-member) asymmetries, and which dataset each number
# comes from, stand out. Example: M3L vs M3R.
#
# To compare a different pair, replace every .../cell/M3L and .../cell/M3R below
# (they appear in the two SUM(IF ...) columns and in the FILTER).
#
# Notes:
#  - The ?dataset column names which of the 17 datasets a row's weights come from; a
#    partner recorded in several datasets produces several rows. (Drop ?dataset from
#    SELECT and GROUP BY to instead sum each partner across all datasets.) Rows are also
#    split by ?type because units differ: chemical / gap_junction = EM serial-section
#    counts; functional = signed Randi values (can be negative). Don't compare across types.
#  - To restrict to one dataset, add inside WHERE:
#      ?c cckg:dataset <https://wormbase.org/resources/connectome/dataset/white_1986_whole> .
#  - To show only rows that differ between the two cells, append:
#      HAVING (?cell_M3L != ?cell_M3R)
PREFIX cckg: <https://wormbase.org/resources/connectome/>
PREFIX dcterms: <http://purl.org/dc/terms/>

SELECT ?partner ?type ?dataset
       (SUM(IF(?f = <https://wormbase.org/resources/connectome/cell/M3L>, ?w, 0)) AS ?cell_M3L)
       (SUM(IF(?f = <https://wormbase.org/resources/connectome/cell/M3R>, ?w, 0)) AS ?cell_M3R)
WHERE {
  ?c cckg:connection_type ?type ;
     cckg:weight ?w ;
     cckg:dataset ?d .
  { ?c cckg:pre ?f ; cckg:post ?pc }
  UNION
  { ?c cckg:post ?f ; cckg:pre ?pc }
  FILTER(?f IN (<https://wormbase.org/resources/connectome/cell/M3L>,
                <https://wormbase.org/resources/connectome/cell/M3R>))
  ?pc dcterms:title ?partner .
  BIND(REPLACE(STR(?d), ".*/dataset/", "") AS ?dataset)
}
GROUP BY ?partner ?type ?dataset
ORDER BY ?type ?partner ?dataset
